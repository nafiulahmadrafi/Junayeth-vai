      <div class="orow"><div class="oname"><span>Kalbela</span><span style="color:var(--muted)">+0.04</span></div><div class="btrack"><div class="bpos" style="width:36%"></div><div class="bneu" style="width:42%"></div><div class="bneg" style="width:22%"></div></div></div>
      <div class="orow"><div class="oname"><span>Dhaka Tribune</span><span style="color:var(--success)">+0.15</span></div><div class="btrack"><div class="bpos" style="width:44%"></div><div class="bneu" style="width:38%"></div><div class="bneg" style="width:18%"></div></div></div>
      <div class="orow"><div class="oname"><span>BD News 24</span><span style="color:var(--muted)">-0.06</span></div><div class="btrack"><div class="bpos" style="width:30%"></div><div class="bneu" style="width:40%"></div><div class="bneg" style="width:30%"></div></div></div>
