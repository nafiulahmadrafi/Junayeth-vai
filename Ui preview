<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Political Media Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#080c14; --surface:#0e1420; --surface2:#141c2e;
  --border:rgba(255,255,255,0.07);
  --accent1:#4f7cff; --accent2:#a855f7; --accent3:#22d3ee;
  --danger:#f43f5e; --warn:#f59e0b; --success:#10b981;
  --text:#e2e8f0; --muted:#64748b;
  --glow:0 0 40px rgba(79,124,255,0.15);
  --r:12px; --sw:240px;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{font-size:16px;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(rgba(79,124,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(79,124,255,0.03) 1px,transparent 1px);
  background-size:40px 40px;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:2px;}

/* LAYOUT */
.layout{display:flex;min-height:100vh;position:relative;z-index:1;}

/* SIDEBAR */
.sidebar{
  width:var(--sw);flex-shrink:0;background:var(--surface);
  border-right:1px solid var(--border);padding:24px 0 0;
  display:flex;flex-direction:column;
  position:fixed;top:0;left:0;height:100vh;z-index:200;
  transition:transform .3s cubic-bezier(.4,0,.2,1);overflow-y:auto;
}
.sb-logo{padding:0 20px 18px;border-bottom:1px solid var(--border);}
.logo-txt{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:800;
  background:linear-gradient(135deg,var(--accent1),var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1.2;}
.logo-sub{font-size:.63rem;color:var(--muted);margin-top:2px;}
.sb-close{display:none;position:absolute;top:16px;right:14px;
  background:rgba(255,255,255,.06);border:none;color:var(--muted);
  width:28px;height:28px;border-radius:6px;font-size:.9rem;cursor:pointer;
  align-items:center;justify-content:center;}
.sb-sec{padding:16px 20px 0;}
.sb-lbl{font-size:.6rem;font-weight:600;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px;}
.cat{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:8px;
  font-size:.74rem;cursor:pointer;margin-bottom:2px;transition:all .15s;user-select:none;}
.cat:hover{background:rgba(79,124,255,.1);}
.cat.on{background:rgba(79,124,255,.15);color:var(--accent1);}
.cdot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.cnt{margin-left:auto;font-size:.6rem;background:rgba(255,255,255,.06);padding:1px 6px;border-radius:10px;color:var(--muted);}
.scan-btn{
  margin:14px 20px;padding:11px;
  background:linear-gradient(135deg,var(--accent1),var(--accent2));
  border:none;border-radius:10px;font-family:'Syne',sans-serif;font-weight:700;
  font-size:.82rem;color:#fff;cursor:pointer;letter-spacing:.03em;
  box-shadow:0 4px 20px rgba(79,124,255,.3);position:relative;overflow:hidden;width:calc(100% - 40px);
}
.scan-btn::after{content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.12),transparent);
  transform:translateX(-100%);animation:shimmer 2s infinite;}
@keyframes shimmer{to{transform:translateX(100%);}}
.tier-leg{padding:0 20px 24px;margin-top:auto;}
.tbadge{display:inline-flex;align-items:center;gap:4px;font-size:.6rem;padding:3px 8px;border-radius:6px;margin:2px 2px 0 0;font-weight:600;}
.t1{background:rgba(16,185,129,.15);color:var(--success);}
.t2{background:rgba(79,124,255,.15);color:var(--accent1);}
.t3{background:rgba(168,85,247,.15);color:var(--accent2);}

/* OVERLAY */
.overlay{display:none;position:fixed;inset:0;z-index:190;background:rgba(0,0,0,.6);backdrop-filter:blur(2px);}
.overlay.on{display:block;}

/* TOPBAR (mobile) */
.topbar{display:none;position:fixed;top:0;left:0;right:0;z-index:150;
  background:var(--surface);border-bottom:1px solid var(--border);
  height:52px;padding:0 14px;align-items:center;justify-content:space-between;}
.topbar-logo{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:800;
  background:linear-gradient(135deg,var(--accent1),var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.menu-btn{background:rgba(255,255,255,.06);border:1px solid var(--border);
  color:var(--text);width:36px;height:36px;border-radius:8px;font-size:1.1rem;
  cursor:pointer;display:flex;align-items:center;justify-content:center;}
.top-live{display:flex;align-items:center;gap:5px;font-size:.63rem;color:var(--success);font-weight:600;}

/* MAIN */
.main{flex:1;margin-left:var(--sw);padding:28px;min-width:0;}

/* HEADER */
.hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px;gap:12px;}
.hdr-title{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;
  background:linear-gradient(135deg,#fff 30%,var(--accent1));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1.2;}
.hdr-sub{font-size:.73rem;color:var(--muted);margin-top:3px;}
.live-bdg{display:flex;align-items:center;gap:6px;flex-shrink:0;
  background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2);
  padding:6px 12px;border-radius:20px;font-size:.68rem;color:var(--success);font-weight:600;}
.ldot{width:6px;height:6px;border-radius:50%;background:var(--success);animation:pulse 1.5s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(1.4);}}

/* METRICS */
.metrics{display:grid;grid-template-columns:repeat(5,1fr);gap:11px;margin-bottom:18px;}
.mc{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px;position:relative;overflow:hidden;transition:transform .2s,box-shadow .2s;}
.mc:hover{transform:translateY(-2px);box-shadow:var(--glow);}
.mc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent1),var(--accent2));}
.mc.d::before{background:var(--danger);}
.mc.w::before{background:var(--warn);}
.mc.s::before{background:var(--success);}
.ml{font-size:.6rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px;}
.mv{font-family:'Syne',sans-serif;font-size:1.65rem;font-weight:800;line-height:1;}
.md{font-size:.62rem;margin-top:4px;}
.up{color:var(--success);} .dn{color:var(--danger);}

/* TABS */
.tabs{display:flex;gap:2px;border-bottom:1px solid var(--border);margin-bottom:16px;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.tabs::-webkit-scrollbar{display:none;}
.tab{padding:9px 14px;font-size:.73rem;font-weight:500;color:var(--muted);cursor:pointer;border-radius:8px 8px 0 0;transition:all .15s;border-bottom:2px solid transparent;margin-bottom:-1px;white-space:nowrap;flex-shrink:0;}
.tab:hover{color:var(--text);background:rgba(255,255,255,.03);}
.tab.on{color:var(--accent1);border-bottom-color:var(--accent1);background:rgba(79,124,255,.05);}

/* PANELS */
.panel{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:18px;}
.ptitle{font-family:'Syne',sans-serif;font-size:.8rem;font-weight:700;margin-bottom:13px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.ptitle span{color:var(--muted);font-size:.66rem;font-weight:400;font-family:'DM Sans',sans-serif;}

/* GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-bottom:13px;}

/* SENTIMENT BARS */
.orow{margin-bottom:8px;}
.oname{font-size:.68rem;color:var(--muted);margin-bottom:3px;display:flex;justify-content:space-between;}
.btrack{height:7px;background:rgba(255,255,255,.05);border-radius:4px;overflow:hidden;display:flex;}
.bpos{background:var(--success);height:100%;}
.bneu{background:var(--muted);height:100%;opacity:.35;}
.bneg{background:var(--danger);height:100%;}
.legrow{display:flex;gap:10px;margin-top:9px;flex-wrap:wrap;}
.legi{display:flex;align-items:center;gap:5px;font-size:.6rem;color:var(--muted);}
.legdot{width:7px;height:7px;border-radius:2px;}

/* PIE */
.fake-pie{width:105px;height:105px;border-radius:50%;flex-shrink:0;
  background:conic-gradient(#4f7cff 0% 32%,#a855f7 32% 55%,#22d3ee 55% 72%,#10b981 72% 85%,#f59e0b 85% 94%,#f43f5e 94% 100%);
  box-shadow:0 0 28px rgba(79,124,255,.2);}
.pielegend{display:flex;flex-direction:column;gap:5px;flex:1;}
.pieit{display:flex;align-items:center;gap:7px;font-size:.67rem;}
.piedot{width:7px;height:7px;border-radius:2px;flex-shrink:0;}
.piepct{margin-left:auto;color:var(--muted);}
.pie-wrap{display:flex;align-items:center;gap:16px;}

/* HEATMAP */
.heatmap{width:100%;border-collapse:collapse;font-size:.66rem;}
.heatmap th{padding:6px 7px;text-align:center;color:var(--muted);font-weight:500;font-size:.6rem;letter-spacing:.05em;border-bottom:1px solid var(--border);white-space:nowrap;}
.heatmap td{padding:6px 7px;text-align:center;}
.ol{text-align:left!important;color:var(--text);font-size:.66rem;white-space:nowrap;}
.hc{border-radius:4px;font-weight:600;font-size:.63rem;display:inline-block;min-width:28px;padding:3px 3px;text-align:center;}
.h0{background:rgba(79,124,255,.04);color:var(--muted);}
.h1{background:rgba(79,124,255,.13);color:rgba(79,124,255,.8);}
.h2{background:rgba(79,124,255,.28);color:var(--accent1);}
.h3{background:rgba(79,124,255,.48);color:#fff;}
.h4{background:var(--accent1);color:#fff;}

/* NARRATIVES */
.narr{border-left:3px solid var(--accent2);padding:10px 12px;background:rgba(168,85,247,.05);border-radius:0 9px 9px 0;margin-bottom:8px;}
.narr.coord{border-left-color:var(--danger);background:rgba(244,63,94,.05);}
.narr-phrase{font-weight:600;font-size:.8rem;margin-bottom:4px;}
.narr-meta{font-size:.63rem;color:var(--muted);}
.narr-hdr{display:flex;align-items:center;gap:6px;margin-bottom:4px;flex-wrap:wrap;}
.cbadge{font-size:.58rem;padding:2px 7px;border-radius:10px;font-weight:700;background:rgba(244,63,94,.15);color:var(--danger);white-space:nowrap;}
.obadge{font-size:.58rem;padding:2px 7px;border-radius:10px;font-weight:700;background:rgba(245,158,11,.15);color:var(--warn);white-space:nowrap;}

/* THREAT */
.tcard{background:rgba(244,63,94,.06);border:1px solid rgba(244,63,94,.2);border-radius:var(--r);padding:13px;margin-bottom:9px;border-left:4px solid var(--danger);}
.ttitle{font-weight:700;font-size:.8rem;color:var(--danger);margin-bottom:4px;}
.tdetail{font-size:.7rem;color:var(--muted);margin-bottom:7px;line-height:1.5;}
.tchips{display:flex;flex-wrap:wrap;gap:5px;}
.chip{font-size:.58rem;padding:3px 8px;border-radius:6px;background:rgba(255,255,255,.06);color:var(--text);border:1px solid var(--border);}

/* SCORE BARS */
.srow{display:flex;align-items:center;gap:8px;margin-bottom:6px;}
.slbl{font-size:.66rem;flex:1;min-width:65px;}
.sbar{flex:2;height:5px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden;}
.sfill{height:100%;border-radius:3px;}
.sval{font-size:.66rem;width:22px;text-align:right;}

/* PREDICTIONS */
.pcard{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);padding:13px;margin-bottom:8px;display:flex;align-items:flex-start;gap:11px;}
.prank{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;color:rgba(255,255,255,.08);flex-shrink:0;line-height:1;}
.pbody{flex:1;min-width:0;}
.ptheme{font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;margin-bottom:2px;}
.ptxt{font-size:.67rem;color:var(--muted);line-height:1.5;}
.psig{flex-shrink:0;text-align:right;}
.spct{font-family:'Syne',sans-serif;font-size:1.25rem;font-weight:800;line-height:1;}
.slabel{font-size:.56rem;color:var(--muted);}
.sbar2{width:44px;height:3px;background:rgba(255,255,255,.07);border-radius:2px;margin-top:4px;}
.sfill2{height:100%;border-radius:2px;}

/* TIER LABELS */
.tt1{color:var(--success);font-size:.6rem;}
.tt2{color:var(--accent1);font-size:.6rem;}
.tt3{color:var(--accent2);font-size:.6rem;}

/* BOTTOM NAV (mobile only) */
.botnav{display:none;position:fixed;bottom:0;left:0;right:0;z-index:150;
  background:var(--surface);border-top:1px solid var(--border);
  padding:8px 0 max(8px,env(safe-area-inset-bottom));}
.botnav-inner{display:flex;justify-content:space-around;align-items:center;}
.nit{display:flex;flex-direction:column;align-items:center;gap:2px;cursor:pointer;padding:4px 8px;border-radius:8px;transition:all .15s;min-width:48px;}
.nit.on{background:rgba(79,124,255,.12);}
.nico{font-size:1.05rem;}
.nlbl{font-size:.53rem;color:var(--muted);font-weight:500;white-space:nowrap;}
.nit.on .nlbl{color:var(--accent1);}

/* ════════════════════════════
   RESPONSIVE
════════════════════════════ */
@media(max-width:1024px){
  .metrics{grid-template-columns:repeat(3,1fr);}
}

@media(max-width:768px){
  .topbar{display:flex;}
  .live-bdg{display:none;}
  .sb-close{display:flex;}
  .sidebar{transform:translateX(-100%);box-shadow:4px 0 30px rgba(0,0,0,.5);}
  .sidebar.on{transform:translateX(0);}
  .main{margin-left:0;padding:64px 12px 76px;}
  .hdr{flex-direction:column;gap:6px;margin-bottom:14px;}
  .hdr-title{font-size:1.2rem;}
  .hdr-sub{font-size:.68rem;}
  .metrics{grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:12px;}
  .mc{padding:11px;}
  .mv{font-size:1.45rem;}
  .ml{font-size:.56rem;}
  .g2{grid-template-columns:1fr;gap:10px;}
  .pie-wrap{flex-direction:column;align-items:center;gap:12px!important;}
  .fake-pie{width:90px;height:90px;}
  .tab{padding:8px 10px;font-size:.68rem;}
  .panel{padding:13px;}
  .ptitle{font-size:.76rem;margin-bottom:11px;}
  .pcard{padding:11px;gap:9px;}
  .prank{font-size:1.1rem;}
  .ptheme{font-size:.78rem;}
  .ptxt{font-size:.64rem;}
  .spct{font-size:1.1rem;}
  .botnav{display:block;}
}

@media(max-width:390px){
  .main{padding:60px 10px 72px;}
  .metrics{gap:7px;}
  .mv{font-size:1.3rem;}
  .tab{padding:7px 8px;font-size:.63rem;}
  .panel{padding:11px;}
}
</style>
</head>
