    <div class="tab">⚠️ Threats</div>
    <div class="tab">🔮 Prediction</div>
    <div class="tab">🔬 Raw Data</div>
  </div>

  <!-- Row 1 -->
  <div class="g2">
    <div class="panel">
      <div class="ptitle">🌡️ Sentiment by Outlet <span>top 7</span></div>
      <div class="orow"><div class="oname"><span>Daily Star</span><span style="color:var(--success)">+0.31</span></div><div class="btrack"><div class="bpos" style="width:55%"></div><div class="bneu" style="width:30%"></div><div class="bneg" style="width:15%"></div></div></div>
